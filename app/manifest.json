{
  "manifest_version": 3,
  "name": "Google Translate Audio Looper",
  "version": "1.0.0",
  "description": "A productivity tool for language learners to loop audio playback on Google Translate.",
  "icons": {
    "16": "icons/logo_16.png",
    "48": "icons/logo_48.png",
    "128": "icons/logo_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/logo_16.png",
      "48": "icons/logo_48.png",
      "128": "icons/logo_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://translate.google.com/*",
        "*://translate.google.com.tw/*",
        "*://translate.google.com.hk/*",
        "*://translate.google.cn/*",
        "*://translate.google.jp/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}